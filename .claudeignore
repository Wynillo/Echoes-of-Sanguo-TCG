# Binary / image assets
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
public/audio/

# Large data files — read explicitly when needed (in @wynillo/echoes-mod-base package)
node_modules/@wynillo/echoes-mod-base/tcg-src/locales/
node_modules/@wynillo/echoes-mod-base/tcg-src/opponents/
node_modules/@wynillo/echoes-mod-base/tcg-src/img/

# Locale files (large flat key-value maps)
locales/en.json
locales/de.json

# Stylesheets — read explicitly when doing CSS work
css/
*.module.css

# Tests — read explicitly when writing/fixing tests
tests/
tests-e2e/

# Documentation — read explicitly when needed
docs/

# CI/CD configuration
.github/

# Generated / build artifacts
package-lock.json
dist/
android/
public/base.tcg
