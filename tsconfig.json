{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "strictNullChecks": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "resolveJsonModule": true
  },
  "include": ["js/**/*.ts", "js/**/*.js", "js/**/*.tsx"]
}
