{
  "name": "@wynillo/tcg-format",
  "version": "1.0.0",
  "description": "TCG Format library for Echoes of Sanguo — load, validate, and pack .tcg archives",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tcg-format": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wynillo/Echoes-of-Sanguo-TCG.git"
  },
  "license": "MIT",
  "files": [
    "dist"
  ]
}
