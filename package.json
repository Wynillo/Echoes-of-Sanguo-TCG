{
  "name": "eos-engine",
  "version": "1.2.0",
  "description": "Ein browser-basiertes Sammelkartenspiel im Stil von Yu-Gi-Oh! Forbidden Memories",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build",
    "test:e2e": "playwright test",
    "build:android": "vite build && cap sync android",
    "cap:sync": "cap sync",
    "cap:open": "cap open android",
    "generate:engine-dts": "node scripts/generate-engine-dts.js",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Wynillo/Echoes-of-Sanguo-ENGINE.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@asamuzakjp/css-color": "~4.1.2",
    "lru-cache": "~11.2.7",
    "@babel/helper-compilation-targets": {
      "lru-cache": "^5.1.1"
    },
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "@xmldom/xmldom": "^0.8.12",
    "serialize-javascript": "^7.0.5",
    "lodash": "^4.18.1",
    "workbox-build": {
      "brace-expansion": "^5.0.5"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@wynillo/echoes-mod-base": "github:Wynillo/Echoes-of-sanguo-MOD-base",
    "@wynillo/tcg-format": "github:Wynillo/Echoes-of-Sanguo-TCG",
    "gsap": "^3.14.2",
    "i18next": "^25.10.10",
    "jszip": "3.10.1",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-icons": "^5.6.0"
  }
}
